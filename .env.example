OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5.2
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Reverse Engineer
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
XAI_API_KEY=
XAI_MODEL=grok-4-fast-reasoning
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-medium-latest
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
# --- KiloCode & OpenCode (Specialized) ---
KILOCODE_API_KEY=
KILOCODE_BASE_URL=https://api.kilo.ai/api/gateway
KILOCODE_MODEL=kilocode/kilo/auto

OPENCODE_API_KEY=
OPENCODE_BASE_URL=https://api.opencode.ai/v1
OPENCODE_MODEL=gpt-4o

# --- System Configuration ---
DEFAULT_PROVIDER=openai
GITHUB_TOKEN=optional_github_token
AUDITOR_API_URL=http://localhost:4040
PORT=4040
MIBU_ALLOW_INSECURE_TLS=0
BROWSER_LAUNCH_TIMEOUT_MS=25000
BROWSER_FETCH_TIMEOUT_MS=20000
# Optional on Windows if Playwright's bundled browser fails to launch:
# BROWSER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# BROWSER_CHANNEL=chrome
# Set to 1 only when your provider endpoint is behind a self-signed or intercepted TLS certificate.
# You can also scope this per provider, e.g. KILOCODE_ALLOW_INSECURE_TLS=1

# --- Gemini Note ---
# GEMINI_API_KEY can be a standard API key OR a Bearer token (ya29...) for OAuth.

# --- Cline API ---
CLINE_API_KEY=
CLINE_MODEL=anthropic/claude-sonnet-4-6
CLINE_BASE_URL=https://api.cline.bot/api/v1
