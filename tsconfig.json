{
  "compilerOptions": {
    // --- Output ---
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "src/*": ["src/*"]
    },
    "outDir": "dist",
    "rootDir": ".",

    // --- Type Safety ---
    "strict": true,
    "noUncheckedIndexedAccess": false,
    "noImplicitOverride": true,
    "noImplicitAny": false,
    "strictNullChecks": false,

    // --- Interop ---
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "downlevelIteration": true,

    // --- Libs & Types ---
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],

    // --- Source Maps (for debugging / ts-node) ---
    "sourceMap": true,
    "declaration": true,

    // --- Misc ---
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "index.ts",
    "index.tsx",
    "cli/**/*.ts",
    "cli/**/*.tsx",
    "server/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "core/**/*.ts",
    "engine/**/*.ts",
    "tools/**/*.ts",
    "auth/**/*.ts",
    "lab/**/*.tsx",
    "lab/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "output",
    "workspaces",
    "media"
  ]
}
